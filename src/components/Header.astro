---
// Header.astro
const currentPath = Astro.url.pathname;

const navItems = [
  { name: 'Dashboard', path: '/dashboard' },
  { name: 'Calculator', path: '/assess' },
  { name: 'AI Coach', path: '/coach' },
  { name: 'Simulator', path: '/simulator' },
  { name: 'Daily Challenges', path: '/challenges' },
  { name: 'Leaderboard', path: '/leaderboard' },
];
---
<header class="sticky top-0 z-50 w-full border-b border-hairline-soft bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl h-16 items-center justify-between px-6">
    <!-- Brand Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <span class="font-display text-2xl font-bold tracking-tight text-primary transition-colors group-hover:text-primary-deep">
        GreePlus <span class="font-mono font-medium text-ink">AI_</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-6">
      {navItems.map((item) => {
        const isActive = currentPath === item.path || currentPath.startsWith(item.path + '/');
        return (
          <a
            href={item.path}
            class={`text-sm font-medium transition-colors ${
              isActive 
                ? 'text-primary border-b-2 border-primary py-1' 
                : 'text-slate hover:text-ink py-1'
            }`}
          >
            {item.name}
          </a>
        );
      })}
    </nav>

    <!-- Header Actions -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href="/assess"
        class="inline-block rounded-md bg-primary px-5 py-2 text-sm font-medium text-on-primary transition-colors hover:bg-primary-deep active:bg-primary-deep"
      >
        Assess Footprint
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-toggle"
      class="flex size-10 items-center justify-center rounded-md border border-hairline-strong text-ink md:hidden focus:outline-none"
      aria-label="Toggle navigation menu"
    >
      <svg
        id="menu-icon-open"
        class="size-6 block"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
      <svg
        id="menu-icon-close"
        class="size-6 hidden"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Dropdown Navigation -->
  <div
    id="mobile-menu"
    class="hidden md:hidden w-full border-t border-hairline-soft bg-canvas px-6 py-4 flex-col gap-4 absolute left-0 right-0 top-16 shadow-lg transition-all"
  >
    <nav class="flex flex-col gap-4">
      {navItems.map((item) => {
        const isActive = currentPath === item.path || currentPath.startsWith(item.path + '/');
        return (
          <a
            href={item.path}
            class={`text-base font-medium px-2 py-1.5 rounded-md transition-colors ${
              isActive 
                ? 'bg-cream text-primary font-semibold' 
                : 'text-slate hover:bg-surface hover:text-ink'
            }`}
          >
            {item.name}
          </a>
        );
      })}
      <div class="h-px bg-hairline-soft my-2"></div>
      <a
        href="/assess"
        class="w-full text-center inline-block rounded-md bg-primary px-5 py-2.5 text-base font-medium text-on-primary hover:bg-primary-deep"
      >
        Assess Footprint
      </a>
    </nav>
  </div>
</header>

<script>
  // Dynamic JavaScript for mobile menu toggling
  const button = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  if (button && menu && openIcon && closeIcon) {
    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
      
      menu.classList.toggle('hidden');
      menu.classList.toggle('flex');
      openIcon.classList.toggle('hidden');
      openIcon.classList.toggle('block');
      closeIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('block');
    });
  }
</script>
