---
// src/pages/coach.astro
import Layout from '../layouts/Layout.astro';
import CoachComponent from '../components/Coach.jsx';
---

<Layout 
  title="AI Sustainability Coach – GreePlus AI" 
  description="Consult the Google Gemini Sustainability Coach for personalized suggestions, prioritized action steps, and interactive carbon reduction plans."
>
  <div class="bg-canvas py-12">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-10">
        <span class="text-xs font-semibold uppercase tracking-wider text-primary">Coaching</span>
        <h1 class="font-display text-4xl font-normal text-ink mt-2 leading-tight">
          AI Sustainability Coach
        </h1>
        <p class="text-slate mt-2">
          Receive prioritized reduction strategies based on your footprint profile. Chat with the coach for custom carbon reduction calculations.
        </p>
      </div>

      <!-- AI Coach React Island -->
      <CoachComponent client:load />
    </div>
  </div>
</Layout>
