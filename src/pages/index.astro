---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import QuickCheck from '../components/QuickCheck.jsx';
---

<Layout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-canvas py-20 lg:py-32">
    <!-- Atmospheric subtle background glow -->
    <div class="absolute top-0 right-0 -z-10 h-[500px] w-[500px] rounded-full bg-sunshine-300/10 blur-3xl"></div>
    <div class="absolute bottom-10 left-10 -z-10 h-[400px] w-[400px] rounded-full bg-primary/5 blur-3xl"></div>

    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <!-- Hero Text -->
        <div class="flex flex-col gap-6 max-w-xl">
          <div class="inline-flex items-center">
            <span class="rounded-full bg-cream-deeper px-3 py-1 text-xs font-bold uppercase tracking-wider text-ink">
              Introducing GreePlus AI
            </span>
          </div>
          <h1 class="font-display text-5xl md:text-6xl lg:text-[76px] font-normal leading-[1.05] tracking-tighter text-ink">
            Carbon awareness.<br />In your hands.
          </h1>
          <p class="font-sans text-lg md:text-xl text-slate leading-relaxed">
            Understand, monitor, and reduce your daily environmental footprint. Get personalized AI recommendations, run simulations on lifestyle changes, and complete daily challenges.
          </p>
          <div class="flex flex-wrap gap-4 pt-2">
            <a
              href="/assess"
              class="rounded-md bg-primary px-6 py-3.5 text-base font-semibold text-on-primary shadow-sm transition-colors hover:bg-primary-deep active:bg-primary-deep"
            >
              Calculate Your Footprint
            </a>
            <a
              href="/simulator"
              class="rounded-md border border-hairline-strong bg-canvas px-6 py-3.5 text-base font-semibold text-ink shadow-sm transition-colors hover:bg-surface"
            >
              Simulate Lifestyle Changes
            </a>
          </div>
        </div>

        <!-- Hero Visual (Sunset Mountains SVG Graphic) -->
        <div class="relative w-full aspect-[4/3] rounded-lg overflow-hidden border border-beige-deep bg-surface shadow-xl">
          <!-- Sunset Vector Art -->
          <svg class="absolute inset-0 size-full" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <!-- Sky Sunset Gradient -->
              <linearGradient id="skyGrad" x1="400" y1="0" x2="400" y2="600" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#fa520f" />
                <stop offset="35%" stop-color="#ffa110" />
                <stop offset="65%" stop-color="#ffb83e" />
                <stop offset="90%" stop-color="#ffd900" />
                <stop offset="100%" stop-color="#fff8e0" />
              </linearGradient>
              <!-- Sun Gradient -->
              <radialGradient id="sunGrad" cx="400" cy="380" r="120" fx="400" fy="380" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
                <stop offset="40%" stop-color="#ffd900" stop-opacity="0.8" />
                <stop offset="100%" stop-color="#ffa110" stop-opacity="0" />
              </radialGradient>
              <!-- Mountain Gradients -->
              <linearGradient id="mountGradBack" x1="400" y1="300" x2="400" y2="600" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#4a4a4a" />
                <stop offset="100%" stop-color="#1f1f1f" />
              </linearGradient>
              <linearGradient id="mountGradFront" x1="400" y1="380" x2="400" y2="600" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#2c2c2c" />
                <stop offset="100%" stop-color="#1f1f1f" />
              </linearGradient>
            </defs>
            <!-- Background Sky -->
            <rect width="800" height="600" fill="url(#skyGrad)" />
            
            <!-- Glowing Sun -->
            <circle cx="400" cy="380" r="120" fill="url(#sunGrad)" />

            <!-- Back Mountain Range -->
            <path d="M0 450 L120 360 L280 430 L450 320 L620 440 L720 380 L800 420 L800 600 L0 600 Z" fill="url(#mountGradBack)" opacity="0.85" />

            <!-- Front Mountain Range -->
            <path d="M0 520 L180 420 L350 490 L520 400 L680 485 L800 430 L800 600 L0 600 Z" fill="url(#mountGradFront)" />
            
            <!-- Horizontal accent lines representing sunset horizon reflection -->
            <line x1="100" y1="550" x2="700" y2="550" stroke="#ffa110" stroke-width="2" opacity="0.4" stroke-dasharray="20 10 5 10" />
            <line x1="200" y1="565" x2="600" y2="565" stroke="#fa520f" stroke-width="2" opacity="0.3" stroke-dasharray="30 15" />
          </svg>
          
          <!-- Decorative code overlay representing Gemini Coach -->
          <div class="absolute bottom-6 left-6 right-6 rounded-md bg-surface-code/90 p-4 backdrop-blur-sm shadow-lg border border-white/10 text-xs font-mono text-on-dark leading-relaxed">
            <div class="flex items-center justify-between pb-2 mb-2 border-b border-white/10 text-on-dark-muted">
              <span>gemini-sustainability-coach.py</span>
              <span class="size-2 rounded-full bg-green-500"></span>
            </div>
            <p class="text-[#ffa110]">>>> coach.analyze_footprint(user_data)</p>
            <p class="text-on-dark mt-1">"Transportation accounts for <span class="text-red-400">52%</span> of your emissions. Replacing two weekly car trips with public transport could reduce <span class="text-green-400">110 kg CO₂</span> annually."</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Calculator section -->
  <section class="bg-cream border-y border-beige-deep py-16">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5 flex flex-col gap-4">
          <span class="text-xs font-semibold uppercase tracking-wider text-primary">Interactive Demo</span>
          <h2 class="font-display text-4xl font-normal leading-tight text-ink">
            Check your transport impact instantly
          </h2>
          <p class="text-slate leading-relaxed">
            Find out how much CO₂ you produce in your weekly commute. Compare a personal gasoline vehicle against public transit, train, or cycling.
          </p>
          <div class="mt-4">
            <a href="/assess" class="text-sm font-semibold text-primary hover:underline flex items-center gap-1">
              Start full multi-category assessment 
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
        <div class="lg:col-span-7">
          <QuickCheck client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- Core Features Grid -->
  <section class="py-20 lg:py-24 bg-canvas">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 flex flex-col gap-4">
        <span class="text-xs font-semibold uppercase tracking-wider text-primary">Core Modules</span>
        <h2 class="font-display text-4xl md:text-5xl font-normal text-ink leading-tight">
          Tools built for measurable action
        </h2>
        <p class="text-slate">
          Static calculators only report a score. GreePlus AI provides a comprehensive loop of tracking, planning, and gamification to create lasting behavioral change.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Feature 1: Carbon Assessment -->
        <div class="rounded-lg border border-hairline-soft bg-canvas p-8 flex flex-col gap-4">
          <div class="size-12 rounded-md bg-cream border border-beige-deep flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18m9-9H3" /></svg>
          </div>
          <h3 class="font-sans text-xl font-semibold text-ink">1. Footprint Assessment</h3>
          <p class="text-sm text-slate leading-relaxed">
            Detailed, multi-category calculator evaluating transportation, home energy, food diet, shopping, and waste management practices.
          </p>
          <a href="/assess" class="text-sm font-medium text-primary hover:underline mt-auto">Open Calculator &rarr;</a>
        </div>

        <!-- Feature 2: AI Coach -->
        <div class="rounded-lg border border-hairline-soft bg-canvas p-8 flex flex-col gap-4">
          <div class="size-12 rounded-md bg-cream border border-beige-deep flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 21l-1.813-5.096L2 14l5.187-1.808L9 7l1.813 5.192L16 14l-6.187 1.904zM21 5.103L20.25 7.5 19.5 5.103 17.5 4.5l2-0.603L20.25 1.5l0.75 2.397 2 .603-2 .603z" /></svg>
          </div>
          <h3 class="font-sans text-xl font-semibold text-ink">2. AI Sustainability Coach</h3>
          <p class="text-sm text-slate leading-relaxed">
            Personalized reduction roadmaps powered by Google Gemini, recommending action steps prioritized by environmental impact.
          </p>
          <a href="/coach" class="text-sm font-medium text-primary hover:underline mt-auto">Consult Coach &rarr;</a>
        </div>

        <!-- Feature 3: Simulator -->
        <div class="rounded-lg border border-hairline-soft bg-canvas p-8 flex flex-col gap-4">
          <div class="size-12 rounded-md bg-cream border border-beige-deep flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" /></svg>
          </div>
          <h3 class="font-sans text-xl font-semibold text-ink">3. Impact Simulator</h3>
          <p class="text-sm text-slate leading-relaxed">
            Model lifestyle decisions (such as shortening commutes or altering diets) before doing them. See real-time score modifications.
          </p>
          <a href="/simulator" class="text-sm font-medium text-primary hover:underline mt-auto">Simulate Changes &rarr;</a>
        </div>

        <!-- Feature 4: Eco Challenges -->
        <div class="rounded-lg border border-hairline-soft bg-canvas p-8 flex flex-col gap-4">
          <div class="size-12 rounded-md bg-cream border border-beige-deep flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-6.75a1.125 1.125 0 00-1.125 1.125v3.375m9 0h-9m9 0a3 3 0 003-3V9.75a3 3 0 00-3-3h-9a3 3 0 00-3 3v6a3 3 0 003 3" /></svg>
          </div>
          <h3 class="font-sans text-xl font-semibold text-ink">4. Daily Challenges</h3>
          <p class="text-sm text-slate leading-relaxed">
            Participate in gamified action challenges (like reusable bottles or plant-based meals). Earn points and advance levels.
          </p>
          <a href="/challenges" class="text-sm font-medium text-primary hover:underline mt-auto">Join Challenges &rarr;</a>
        </div>

        <!-- Feature 5: Leaderboards -->
        <div class="rounded-lg border border-hairline-soft bg-canvas p-8 flex flex-col gap-4">
          <div class="size-12 rounded-md bg-cream border border-beige-deep flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
          </div>
          <h3 class="font-sans text-xl font-semibold text-ink">5. Community Engagement</h3>
          <p class="text-sm text-slate leading-relaxed">
            Compare progress on Friends Leaderboards or check rankings between College Departments. Promote accountability and healthy competition.
          </p>
          <a href="/leaderboard" class="text-sm font-medium text-primary hover:underline mt-auto">View Leaderboard &rarr;</a>
        </div>

        <!-- Feature 6: Interactive Dashboard -->
        <div class="rounded-lg border border-hairline-soft bg-canvas p-8 flex flex-col gap-4">
          <div class="size-12 rounded-md bg-cream border border-beige-deep flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" /></svg>
          </div>
          <h3 class="font-sans text-xl font-semibold text-ink">6. Analytics Hub</h3>
          <p class="text-sm text-slate leading-relaxed">
            Review detailed, category-wise breakdowns of your emissions. Track progress, reduction history, and streaks in one page.
          </p>
          <a href="/dashboard" class="text-sm font-medium text-primary hover:underline mt-auto">View Dashboard &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- High-impact CTA Banner -->
  <section class="pb-24 pt-10 bg-canvas">
    <div class="mx-auto max-w-7xl px-6">
      <div class="rounded-lg bg-cream border border-beige-deep p-12 md:p-16 flex flex-col items-center text-center gap-6 max-w-4xl mx-auto shadow-sm">
        <h2 class="font-display text-4xl md:text-5xl font-normal leading-tight text-ink max-w-2xl">
          The next chapter of carbon action is yours.
        </h2>
        <p class="text-slate max-w-xl">
          Take 5 minutes to complete the footprint assessment and unlock your personalized sustainability roadmap today.
        </p>
        <div class="pt-2">
          <a
            href="/assess"
            class="inline-block rounded-md bg-ink px-8 py-3.5 text-base font-semibold text-on-dark hover:bg-ink-tint transition-colors"
          >
            Start Footprint Assessment
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
